# --- Portfolio admin environment variables ---
#
# PRODUCTION: set these in Vercel -> your project -> Settings -> Environment Variables.
# LOCAL DEV:  copy this file to ".env.local" and fill in real values, then run `vercel dev`.
#
# Never commit real secrets. ".env" and ".env*.local" are git-ignored.

# The password you type on the /admin page to log in.
ADMIN_PASSWORD=change-me-to-your-password

# A long random string that signs your login cookie.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Auto-added by Vercel when you create a Blob store (Storage tab).
# You normally do NOT set this by hand in production.
# For local dev, copy the token from your Vercel Blob store settings.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
